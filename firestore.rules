rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // petrolBunks — anyone can read, only authenticated users can write (for auto-seed)
    match /petrolBunks/{bunkId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // orders — authenticated users can create and read their own orders
    match /orders/{orderId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || request.auth.token.email in ['admin@fuelflux.com']);
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // vehicles — anyone authenticated can read, only authenticated can write
    match /vehicles/{vehicleId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // userVehicles — users can only read/write their own vehicles
    match /userVehicles/{docId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
  }
}
